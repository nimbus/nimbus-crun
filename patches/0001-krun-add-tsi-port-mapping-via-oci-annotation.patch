 static int
+libkrun_configure_port_map (uint32_t ctx_id, void *handle, libcrun_container_t *container, libcrun_error_t *err)
+{
+  int32_t (*krun_set_port_map) (uint32_t ctx_id, const char *const port_map[]);
+  const char *annotation;
+  cleanup_free char *port_map = NULL;
+  cleanup_free char **entries = NULL;
+  char *entry;
+  char *saveptr = NULL;
+  size_t entries_len = 0;
+  int ret;
+
+  annotation = find_annotation (container, "krun.port_map");
+  if (annotation == NULL || *annotation == '\0')
+    return 0;
+
+  krun_set_port_map = dlsym (handle, "krun_set_port_map");
+  if (krun_set_port_map == NULL)
+    return crun_make_error (err, 0, "could not find symbol in the krun library");
+
+  port_map = xstrdup (annotation);
+  for (entry = strtok_r (port_map, ",", &saveptr); entry != NULL;
+       entry = strtok_r (NULL, ",", &saveptr))
+    entries_len++;
+
+  if (entries_len == 0)
+    return 0;
+
+  free (port_map);
+  port_map = xstrdup (annotation);
+  entries = xmalloc0 (sizeof (*entries) * (entries_len + 1));
+
+  saveptr = NULL;
+  entries_len = 0;
+  for (entry = strtok_r (port_map, ",", &saveptr); entry != NULL;
+       entry = strtok_r (NULL, ",", &saveptr))
+    entries[entries_len++] = entry;
+
+  ret = krun_set_port_map (ctx_id, (const char *const *) entries);
+  if (UNLIKELY (ret < 0))
+    return crun_make_error (err, -ret, "could not set krun port map");
+
+  return 0;
+}
